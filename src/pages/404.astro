---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Page Not Found - RecipeCards" description="The page you're looking for doesn't exist.">

	<div style="max-width: 760px; margin: 0.25rem auto; text-align: center; padding-top: 3rem;">

		<!-- Brand -->
		<div style="margin-bottom: 0.75rem;">
			<a href="/" style="font-family: 'Montserrat', sans-serif; font-size: 0.65rem; font-weight: 600; letter-spacing: 0.2em; text-transform: uppercase; color: var(--color-bc-harvest); text-decoration: none;">RecipeCards</a>
		</div>

		<h1 style="
			font-family: 'Sorts Mill Goudy', serif;
			font-size: 2.4rem;
			font-weight: bold;
			color: var(--color-bc-text);
			text-transform: uppercase;
			letter-spacing: 0.05em;
			line-height: 1.1;
			margin: 0 0 0.75rem;
		">Page Not Found</h1>

		<div style="height: 3px; background: var(--color-bc-harvest); margin: 0 auto 1.75rem; max-width: 200px;"></div>

		<p style="font-family: 'Montserrat', sans-serif; font-size: 0.9rem; color: var(--color-bc-text); line-height: 1.8; margin-bottom: 2rem;">
			Sorry, the page you're looking for doesn't exist or has been moved.
		</p>

		<a href="/" style="
			display: inline-block;
			padding: 0.7rem 1.5rem;
			background-color: var(--color-bc-harvest);
			color: white;
			font-family: 'Montserrat', sans-serif;
			font-size: 0.85rem;
			font-weight: 600;
			text-decoration: none;
			letter-spacing: 0.05em;
		">Browse Recipes</a>

	</div>

</Layout>
