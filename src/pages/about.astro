---
import Layout from '../layouts/Layout.astro';
---

<Layout title="About - RecipeCards" description="About RecipeCards.kitchen — simple, tested recipes for home cooks." canonicalUrl="https://recipecards.kitchen/about/">

	<div style="max-width: 760px; margin: 0.25rem auto;">

		<!-- Brand -->
		<div style="margin-bottom: 0.75rem;">
			<a href="/" style="font-family: 'Montserrat', sans-serif; font-size: 0.65rem; font-weight: 600; letter-spacing: 0.2em; text-transform: uppercase; color: var(--color-bc-harvest); text-decoration: none;">RecipeCards</a>
		</div>

		<h1 style="
			font-family: 'Sorts Mill Goudy', serif;
			font-size: 2.4rem;
			font-weight: bold;
			color: var(--color-bc-text);
			text-transform: uppercase;
			letter-spacing: 0.05em;
			line-height: 1.1;
			margin: 0 0 0.75rem;
		">About</h1>

		<div style="height: 3px; background: var(--color-bc-harvest); margin-bottom: 1.75rem;"></div>

		<div style="font-family: 'Montserrat', sans-serif; font-size: 0.9rem; color: var(--color-bc-text); line-height: 1.8;">

			<h2 style="font-size: 0.65rem; font-weight: 700; letter-spacing: 0.2em; text-transform: uppercase; color: var(--color-bc-harvest); font-family: 'Montserrat', sans-serif; margin: 0 0 0.75rem;">
				What is RecipeCards?
			</h2>
			<p style="margin-bottom: 1rem;">
				Hi, I'm Eric from New York. RecipeCards is a collection of simple, reliable recipes for home cooks. No lengthy stories before the recipe, no pop-ups — just clear ingredients, step-by-step instructions, and helpful tips for getting it right every time.
			</p>

			<h2 style="font-size: 0.65rem; font-weight: 700; letter-spacing: 0.2em; text-transform: uppercase; color: var(--color-bc-harvest); font-family: 'Montserrat', sans-serif; margin: 1.75rem 0 0.75rem;">
				Our Approach
			</h2>
			<p style="margin-bottom: 1rem;">
				Every recipe is written to be practical and repeatable. We include variations so you can adapt dishes to your taste, and troubleshooting tips for common issues. Each recipe card is printable so you can keep it right next to the stove.
			</p>

			<h2 style="font-size: 0.65rem; font-weight: 700; letter-spacing: 0.2em; text-transform: uppercase; color: var(--color-bc-harvest); font-family: 'Montserrat', sans-serif; margin: 1.75rem 0 0.75rem;">
				Features
			</h2>
			<ul style="margin: 0 0 1rem 1.5rem; padding: 0;">
				<li style="margin-bottom: 0.4rem;">Serving multiplier — scale recipes to 0.5x, 1x, or 2x servings</li>
				<li style="margin-bottom: 0.4rem;">Unit conversion — switch between standard and metric measurements</li>
				<li style="margin-bottom: 0.4rem;">Print-friendly — clean printable recipe cards</li>
				<li style="margin-bottom: 0.4rem;">Search — find recipes by name, ingredient, or tag</li>
			</ul>

			<h2 style="font-size: 0.65rem; font-weight: 700; letter-spacing: 0.2em; text-transform: uppercase; color: var(--color-bc-harvest); font-family: 'Montserrat', sans-serif; margin: 1.75rem 0 0.75rem;">
				Contact
			</h2>
			<p style="margin-bottom: 1rem;">
				Have a question, suggestion, or recipe request? Reach out at <a href="mailto:hello@recipecards.kitchen" style="color: var(--color-bc-harvest);">hello@recipecards.kitchen</a>.
			</p>

		</div>
	</div>

</Layout>
