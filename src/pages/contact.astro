---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Contact - RecipeCards" description="Get in touch with the RecipeCards team — questions, suggestions, and recipe requests welcome." canonicalUrl="https://recipecards.kitchen/contact/">

	<div style="max-width: 760px; margin: 0.25rem auto;">

		<!-- Brand -->
		<div style="margin-bottom: 0.75rem;">
			<a href="/" style="font-family: 'Montserrat', sans-serif; font-size: 0.65rem; font-weight: 600; letter-spacing: 0.2em; text-transform: uppercase; color: var(--color-bc-harvest); text-decoration: none;">RecipeCards</a>
		</div>

		<h1 style="
			font-family: 'Sorts Mill Goudy', serif;
			font-size: 2.4rem;
			font-weight: bold;
			color: var(--color-bc-text);
			text-transform: uppercase;
			letter-spacing: 0.05em;
			line-height: 1.1;
			margin: 0 0 0.75rem;
		">Contact</h1>

		<div style="height: 3px; background: var(--color-bc-harvest); margin-bottom: 1.75rem;"></div>

		<div style="font-family: 'Montserrat', sans-serif; font-size: 0.9rem; color: var(--color-bc-text); line-height: 1.8;">

			<p style="margin-bottom: 1.5rem;">
				Have a question, suggestion, or recipe request? We'd love to hear from you.
			</p>

			<p style="margin-bottom: 1.5rem;">
				Reach out at
				<a href="mailto:hello@recipecards.kitchen" style="color: var(--color-bc-harvest); font-weight: 600;">hello@recipecards.kitchen</a>
			</p>

			<p style="margin-bottom: 1rem;">
				We're happy to help with:
			</p>
			<ul style="margin: 0 0 1.5rem 1.5rem; padding: 0;">
				<li style="margin-bottom: 0.4rem;">Recipe questions or cooking tips</li>
				<li style="margin-bottom: 0.4rem;">Suggestions for new recipes</li>
				<li style="margin-bottom: 0.4rem;">Corrections or improvements to existing recipes</li>
				<li style="margin-bottom: 0.4rem;">General feedback about the site</li>
			</ul>

			<p style="margin-bottom: 1rem;">
				We aim to respond within a few business days.
			</p>

		</div>
	</div>

</Layout>
