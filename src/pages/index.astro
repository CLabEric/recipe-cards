---
import Layout from '../layouts/Layout.astro';
import recipesData from '../data/recipes.json'; // Added import

const allTags = [...new Set(recipesData.flatMap(recipe => recipe.tags || []))];
allTags.sort(); // Optional: sort tags alphabetically
---

<Layout title="RecipeCards" description="Discover unique and delicious recipes generated by AI.">
	<section class="text-center">
		<h1 class="text-5xl font-extrabold text-gray-800 mb-6">Welcome to RecipeCards!</h1>
		<p class="text-xl text-gray-600 max-w-2xl mx-auto">
			Discover unique and delicious recipes, crafted by advanced artificial intelligence.
			Get ready to skip the fluff and get cookin!
		</p>
	</section>

    <section class="container mx-auto p-6">
        <h2 class="text-4xl font-semibold text-gray-800 mb-6 text-center">Filter by Category</h2>
        <div class="flex flex-wrap justify-center gap-2 mb-8" id="tag-filters">
            <button class="tag-button bg-lime-500 text-white px-4 py-2 rounded-full hover:bg-lime-600 transition-colors" data-tag="all">All Recipes</button>
            {allTags.map(tag => (
                <button class="tag-button bg-gray-200 text-gray-800 px-4 py-2 rounded-full hover:bg-gray-300 transition-colors" data-tag={tag}>
                    {tag.replace(/-/g, ' ').replace(/\b\w/g, l => l.toUpperCase())}
                </button>
            ))}
        </div>

        <ul class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6" id="recipe-list">
            {recipesData.map((recipe) => (
                <li class="p-4 border border-gray-200 rounded-lg shadow-sm hover:shadow-md transition-shadow" data-tags={(recipe.tags || []).join(',')}>
                    <a href={`/recipes/${recipe.id}`} class="text-xl font-medium" style="color: var(--color-primary);">
                        {recipe.title}
                    </a>
                </li>
            ))}
        </ul>
    </section>

    <script is:inline>
        const tagFilters = document.getElementById('tag-filters');
        const recipeList = document.getElementById('recipe-list');
        const recipeItems = recipeList.querySelectorAll('li');

        tagFilters.addEventListener('click', (event) => {
            const target = event.target;
            if (target.classList.contains('tag-button')) {
                const selectedTag = target.dataset.tag;

                // Update button active state
                tagFilters.querySelectorAll('.tag-button').forEach(button => {
                    button.classList.remove('bg-lime-500', 'text-white');
                    button.classList.add('bg-gray-200', 'text-gray-800');
                });
                target.classList.remove('bg-gray-200', 'text-gray-800');
                target.classList.add('bg-lime-500', 'text-white');

                recipeItems.forEach(item => {
                    const itemTags = item.dataset.tags.split(',');
                    if (selectedTag === 'all' || itemTags.includes(selectedTag)) {
                        item.style.display = 'block';
                    } else {
                        item.style.display = 'none';
                    }
                });
            }
        });
        // Set 'All Recipes' as active on initial load
        document.querySelector('.tag-button[data-tag="all"]').click();
    </script>
</Layout>
