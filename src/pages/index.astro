---
import Layout from '../layouts/Layout.astro';
import Search from 'astro-pagefind/components/Search';
import recipesData from '../data/recipes.json';
import tagsData from '../data/tags.json';

const tagCounts = recipesData
  .flatMap(r => r.tags ?? [])
  .reduce((acc: Record<string, number>, t) => ({ ...acc, [t]: (acc[t] ?? 0) + 1 }), {});

const quickTags = tagsData
  .filter(tag => (tagCounts[tag] ?? 0) >= 3)
  .sort((a, b) => (tagCounts[b] ?? 0) - (tagCounts[a] ?? 0));
const featuredRecipes = recipesData.filter((r) => r.featured).slice(0, 12);
---

<Layout title="RecipeCards — Easy Recipes for Home Cooks" description="Discover unique and delicious recipes generated by AI." canonicalUrl="https://recipecards.kitchen/">

	<div style="max-width: 760px; margin: 0.25rem auto;">

		<!-- Brand -->
		<div style="margin-bottom: 0.75rem;">
			<span style="font-family: 'Montserrat', sans-serif; font-size: 0.65rem; font-weight: 600; letter-spacing: 0.2em; text-transform: uppercase; color: var(--color-bc-harvest);">RecipeCards</span>
		</div>

		<h1 style="
			font-family: 'Sorts Mill Goudy', serif;
			font-size: 2.4rem;
			font-weight: bold;
			color: var(--color-bc-text);
			text-transform: uppercase;
			letter-spacing: 0.05em;
			line-height: 1.1;
			margin: 0 0 0.75rem;
		">Recipes</h1>

		<div style="height: 3px; background: var(--color-bc-harvest); margin-bottom: 1.75rem;"></div>

		<div id="search-container" style="margin-bottom: 1rem;">
			<Search
				id="search"
				className="pagefind-ui"
				uiOptions={{
					showImages: true,
					showEmptyFilters: false,
					resetStyles: false,
				}}
			/>
		</div>

		<!-- Quick tag buttons -->
		<div id="quick-tags" style="display: flex; flex-wrap: wrap; gap: 0.5rem; margin-bottom: 1.75rem;">
			{quickTags.map((tag) => (
				<button class="quick-tag-btn" data-tag={tag}>
					{tag.split('-').map((w: string) => w[0].toUpperCase() + w.slice(1)).join(' ')}
				</button>
			))}
		</div>

		<!-- Featured recipes -->
		<div id="featured-section">
			<h2 style="
				font-size: 0.65rem;
				font-weight: 700;
				letter-spacing: 0.2em;
				text-transform: uppercase;
				color: var(--color-bc-harvest);
				font-family: 'Montserrat', sans-serif;
				margin: 0 0 1rem;
			">Top Recipes</h2>

			<ul style="list-style: none; padding: 0; margin: 0; display: grid; grid-template-columns: repeat(auto-fill, minmax(200px, 1fr)); gap: 1rem;">
				{featuredRecipes.map((recipe) => (
					<li>
						<a href={`/recipes/${recipe.id}`} style="
							display: block;
							padding: 0.9rem 1.1rem;
							background-color: var(--color-bc-parchment);
							border: 1px solid #c9a96e;
							box-shadow: 2px 2px 0 #b8915a, 4px 4px 10px rgba(0,0,0,0.12);
							text-decoration: none;
							font-family: 'Sorts Mill Goudy', serif;
							font-size: 1.05rem;
							color: var(--color-bc-text);
							transition: box-shadow 0.15s ease;
						"
						onmouseover="this.style.boxShadow='3px 3px 0 #b8915a, 6px 6px 14px rgba(0,0,0,0.18)'"
						onmouseout="this.style.boxShadow='2px 2px 0 #b8915a, 4px 4px 10px rgba(0,0,0,0.12)'"
						>
							{recipe.title}
						</a>
					</li>
				))}
			</ul>
		</div>

	</div>

<script is:inline>
	document.addEventListener('DOMContentLoaded', () => {
		const featured = document.getElementById('featured-section');
		const searchContainer = document.getElementById('search-container');
		let activeTag = null;

		// --- Search / featured toggle ---
		function setSearchActive(active) {
			featured.style.display = active ? 'none' : '';
			// Hide Pagefind's results/filters drawer when returning to initial state
			const drawer = searchContainer.querySelector('.pagefind-ui__drawer');
			if (drawer) {
				drawer.style.display = active ? '' : 'none';
			}
		}

		// --- Quick tag buttons ---
		const tagButtons = document.querySelectorAll('.quick-tag-btn');

		function triggerSearch(term) {
			const input = searchContainer.querySelector('.pagefind-ui__search-input');
			if (!input) return;
			input.value = term;
			input.dispatchEvent(new Event('input', { bubbles: true }));
			setSearchActive(true);
		}

		function clearSearch() {
			const input = searchContainer.querySelector('.pagefind-ui__search-input');
			if (!input) return;
			input.value = '';
			input.dispatchEvent(new Event('input', { bubbles: true }));
			const clearBtn = searchContainer.querySelector('.pagefind-ui__search-clear');
			if (clearBtn) clearBtn.click();
			setSearchActive(false);
		}

		tagButtons.forEach(btn => {
			btn.addEventListener('click', () => {
				const tag = btn.dataset.tag;
				if (activeTag === tag) {
					activeTag = null;
					tagButtons.forEach(b => b.classList.remove('quick-tag-btn--active'));
					clearSearch();
				} else {
					activeTag = tag;
					tagButtons.forEach(b => b.classList.remove('quick-tag-btn--active'));
					btn.classList.add('quick-tag-btn--active');
					triggerSearch(tag.replace(/-/g, ' '));
				}
			});
		});

		// --- Watch for Pagefind UI load ---
		const observer = new MutationObserver(() => {
			const input = searchContainer.querySelector('.pagefind-ui__search-input');
			if (!input) return;

			input.addEventListener('input', () => {
				if (input.value.trim()) {
					setSearchActive(true);
				} else {
					activeTag = null;
					tagButtons.forEach(b => b.classList.remove('quick-tag-btn--active'));
					setSearchActive(false);
				}
			});

			const clearBtn = searchContainer.querySelector('.pagefind-ui__search-clear');
			if (clearBtn) {
				clearBtn.addEventListener('click', () => {
					activeTag = null;
					tagButtons.forEach(b => b.classList.remove('quick-tag-btn--active'));
					setSearchActive(false);
				});
			}

			observer.disconnect();
		});

		observer.observe(searchContainer, { childList: true, subtree: true });
	});
</script>

</Layout>