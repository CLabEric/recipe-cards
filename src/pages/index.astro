---
import Layout from '../layouts/Layout.astro';
import recipesData from '../data/recipes.json';
---

<Layout title="RecipeCards" description="Discover unique and delicious recipes generated by AI." canonicalUrl="https://recipecards.kitchen/">

	<div style="max-width: 760px; margin: 0.25rem auto;">

		<!-- Brand -->
		<div style="margin-bottom: 0.75rem;">
			<span style="font-family: 'Montserrat', sans-serif; font-size: 0.65rem; font-weight: 600; letter-spacing: 0.2em; text-transform: uppercase; color: var(--color-bc-harvest);">RecipeCards</span>
		</div>

		<h1 style="
			font-family: 'Sorts Mill Goudy', serif;
			font-size: 2.4rem;
			font-weight: bold;
			color: var(--color-bc-text);
			text-transform: uppercase;
			letter-spacing: 0.05em;
			line-height: 1.1;
			margin: 0 0 0.75rem;
		">All Recipes</h1>

		<div style="height: 3px; background: var(--color-bc-harvest); margin-bottom: 1.75rem;"></div>

		<ul style="list-style: none; padding: 0; margin: 0; display: grid; grid-template-columns: repeat(auto-fill, minmax(200px, 1fr)); gap: 1rem;">
			{recipesData.map((recipe) => (
				<li>
					<a href={`/recipes/${recipe.id}`} style="
						display: block;
						padding: 0.9rem 1.1rem;
						background-color: var(--color-bc-parchment);
						border: 1px solid #c9a96e;
						box-shadow: 2px 2px 0 #b8915a, 4px 4px 10px rgba(0,0,0,0.12);
						text-decoration: none;
						font-family: 'Sorts Mill Goudy', serif;
						font-size: 1.05rem;
						color: var(--color-bc-text);
						transition: box-shadow 0.15s ease;
					"
					onmouseover="this.style.boxShadow='3px 3px 0 #b8915a, 6px 6px 14px rgba(0,0,0,0.18)'"
					onmouseout="this.style.boxShadow='2px 2px 0 #b8915a, 4px 4px 10px rgba(0,0,0,0.12)'"
					>
						{recipe.title}
					</a>
				</li>
			))}
		</ul>

	</div>

</Layout>
