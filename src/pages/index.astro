---
import Layout from '../layouts/Layout.astro';
import Search from 'astro-pagefind/components/Search';
import recipesData from '../data/recipes.json';

const quickTags = ['Italian', 'American', 'Comfort Food', 'Quick', 'Dessert', 'Soup'];
const RECIPES_PER_PAGE = 24;
---

<Layout title="RecipeCards" description="Discover unique and delicious recipes generated by AI." canonicalUrl="https://recipecards.kitchen/">

	<div style="max-width: 760px; margin: 0.25rem auto;">

		<!-- Brand -->
		<div style="margin-bottom: 0.75rem;">
			<span style="font-family: 'Montserrat', sans-serif; font-size: 0.65rem; font-weight: 600; letter-spacing: 0.2em; text-transform: uppercase; color: var(--color-bc-harvest);">RecipeCards</span>
		</div>

		<h1 style="
			font-family: 'Sorts Mill Goudy', serif;
			font-size: 2.4rem;
			font-weight: bold;
			color: var(--color-bc-text);
			text-transform: uppercase;
			letter-spacing: 0.05em;
			line-height: 1.1;
			margin: 0 0 0.75rem;
		">All Recipes</h1>

		<div style="height: 3px; background: var(--color-bc-harvest); margin-bottom: 1.75rem;"></div>

		<div id="search-container" style="margin-bottom: 1rem;">
			<Search
				id="search"
				className="pagefind-ui"
				uiOptions={{
					showImages: true,
					showEmptyFilters: false,
					resetStyles: false,
				}}
			/>
		</div>

		<!-- Quick tag buttons -->
		<div id="quick-tags" style="display: flex; flex-wrap: wrap; gap: 0.5rem; margin-bottom: 1.75rem;">
			{quickTags.map((tag) => (
				<button class="quick-tag-btn" data-tag={tag.toLowerCase().replace(' ', '-')}>
					{tag}
				</button>
			))}
		</div>

		<ul id="recipe-grid" style="list-style: none; padding: 0; margin: 0; display: grid; grid-template-columns: repeat(auto-fill, minmax(200px, 1fr)); gap: 1rem;">
			{recipesData.map((recipe) => (
				<li class="recipe-item">
					<a href={`/recipes/${recipe.id}`} style="
						display: block;
						padding: 0.9rem 1.1rem;
						background-color: var(--color-bc-parchment);
						border: 1px solid #c9a96e;
						box-shadow: 2px 2px 0 #b8915a, 4px 4px 10px rgba(0,0,0,0.12);
						text-decoration: none;
						font-family: 'Sorts Mill Goudy', serif;
						font-size: 1.05rem;
						color: var(--color-bc-text);
						transition: box-shadow 0.15s ease;
					"
					onmouseover="this.style.boxShadow='3px 3px 0 #b8915a, 6px 6px 14px rgba(0,0,0,0.18)'"
					onmouseout="this.style.boxShadow='2px 2px 0 #b8915a, 4px 4px 10px rgba(0,0,0,0.12)'"
					>
						{recipe.title}
					</a>
				</li>
			))}
		</ul>

		<!-- Pagination controls -->
		<div id="pagination" style="display: flex; justify-content: center; align-items: center; gap: 0.5rem; margin-top: 1.5rem;"></div>

	</div>

<script is:inline>
	document.addEventListener('DOMContentLoaded', () => {
		const grid = document.getElementById('recipe-grid');
		const searchContainer = document.getElementById('search-container');
		const paginationContainer = document.getElementById('pagination');
		const items = Array.from(grid.querySelectorAll('.recipe-item'));
		const PER_PAGE = 24;
		let currentPage = 1;
		let activeTag = null;
		let searchActive = false;

		// --- Pagination ---
		function getTotalPages() {
			return Math.max(1, Math.ceil(items.length / PER_PAGE));
		}

		function showPage(page) {
			currentPage = page;
			const start = (page - 1) * PER_PAGE;
			const end = start + PER_PAGE;
			items.forEach((item, i) => {
				item.style.display = (i >= start && i < end) ? '' : 'none';
			});
			renderPagination();
		}

		function renderPagination() {
			const totalPages = getTotalPages();
			if (totalPages <= 1) {
				paginationContainer.innerHTML = '';
				return;
			}

			let html = '';
			html += `<button class="page-btn" data-page="${currentPage - 1}" ${currentPage === 1 ? 'disabled' : ''}>Prev</button>`;

			for (let p = 1; p <= totalPages; p++) {
				html += `<button class="page-btn ${p === currentPage ? 'page-btn--active' : ''}" data-page="${p}">${p}</button>`;
			}

			html += `<button class="page-btn" data-page="${currentPage + 1}" ${currentPage === totalPages ? 'disabled' : ''}>Next</button>`;
			paginationContainer.innerHTML = html;

			paginationContainer.querySelectorAll('.page-btn').forEach(btn => {
				btn.addEventListener('click', () => {
					const page = parseInt(btn.dataset.page);
					if (page >= 1 && page <= totalPages) showPage(page);
				});
			});
		}

		// --- Search / grid toggle ---
		function setSearchActive(active) {
			searchActive = active;
			grid.style.display = active ? 'none' : '';
			paginationContainer.style.display = active ? 'none' : '';
			if (!active) showPage(currentPage);
		}

		// --- Quick tag buttons ---
		const tagButtons = document.querySelectorAll('.quick-tag-btn');

		function triggerSearch(term) {
			const input = searchContainer.querySelector('.pagefind-ui__search-input');
			if (!input) return;
			input.value = term;
			input.dispatchEvent(new Event('input', { bubbles: true }));
			setSearchActive(true);
		}

		function clearSearch() {
			const input = searchContainer.querySelector('.pagefind-ui__search-input');
			if (!input) return;
			input.value = '';
			input.dispatchEvent(new Event('input', { bubbles: true }));
			const clearBtn = searchContainer.querySelector('.pagefind-ui__search-clear');
			if (clearBtn) clearBtn.click();
			setSearchActive(false);
		}

		tagButtons.forEach(btn => {
			btn.addEventListener('click', () => {
				const tag = btn.dataset.tag;
				if (activeTag === tag) {
					// Toggle off
					activeTag = null;
					tagButtons.forEach(b => b.classList.remove('quick-tag-btn--active'));
					clearSearch();
				} else {
					activeTag = tag;
					tagButtons.forEach(b => b.classList.remove('quick-tag-btn--active'));
					btn.classList.add('quick-tag-btn--active');
					triggerSearch(tag);
				}
			});
		});

		// --- Watch for Pagefind UI load ---
		const observer = new MutationObserver(() => {
			const input = searchContainer.querySelector('.pagefind-ui__search-input');
			if (!input) return;

			input.addEventListener('input', () => {
				if (input.value.trim()) {
					setSearchActive(true);
				} else {
					activeTag = null;
					tagButtons.forEach(b => b.classList.remove('quick-tag-btn--active'));
					setSearchActive(false);
				}
			});

			const clearBtn = searchContainer.querySelector('.pagefind-ui__search-clear');
			if (clearBtn) {
				clearBtn.addEventListener('click', () => {
					activeTag = null;
					tagButtons.forEach(b => b.classList.remove('quick-tag-btn--active'));
					setSearchActive(false);
				});
			}

			observer.disconnect();
		});

		observer.observe(searchContainer, { childList: true, subtree: true });

		// Initial render
		showPage(1);
	});
</script>

</Layout>
